# Production build env (loaded by `next build` / `build:cf`).
# NEXT_PUBLIC_* values are inlined into the client bundle, so this is public.
# Orbit's own relay (workers/room, name "orbit-room") — NOT plur.nyc's shared
# mayfly-room. Its ALLOWED_ORIGINS must include this app's deployed origin.
NEXT_PUBLIC_ROOM_API_BASE=https://orbit-room.junting-mp3.workers.dev
