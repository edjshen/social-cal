{
  "name": "barycal",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "deploy:cf": "opennextjs-cloudflare deploy",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "audit:ci": "npm audit --audit-level=high --omit=dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mayfly": "node --test \"lib/mayfly/shared/*.test.js\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply barycal-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply barycal-db --remote",
    "db:seed:local": "tsx scripts/gen-seed.ts && wrangler d1 execute barycal-db --local --file=drizzle/seed.sql",
    "db:seed:remote": "tsx scripts/gen-seed.ts && wrangler d1 execute barycal-db --remote --file=drizzle/seed.sql",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@noble/hashes": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "idb": "^8.0.3",
    "iron-session": "^8.0.4",
    "jsqr": "^1.4.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.15",
    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tweetnacl": "^1.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@serwist/next": "^9.5.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.4.0",
    "patch-package": "^8.0.1",
    "serwist": "^9.5.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
