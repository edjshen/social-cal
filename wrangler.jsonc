{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "social-cal",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "html_handling": "none",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
